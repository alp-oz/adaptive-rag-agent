# Copy this structure into the Streamlit Cloud secrets panel (Settings > Secrets)
# Do NOT commit the real secrets.toml file.

ANTHROPIC_API_KEY = "sk-ant-..."

# Controls which default documents are loaded.
# "finance" — loads built-in banking documents and shows example questions (CV / recruiter demo)
# "none"    — no default documents, user must upload their own (GitHub / general demo)
SAMPLE_DOMAIN = "finance"
